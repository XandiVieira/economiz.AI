    },
    {
      "name": "E2E Flow",
      "description": "Sequential test suite \u2014 run top to bottom. Each step seeds variables for the next.",
      "item": [
        {
          "name": "1. Register new user",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "pt"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            },
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"E2E Test User\",\n  \"email\": \"e2e@test.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var email = 'e2e-' + Date.now() + '@test.com';",
                  "pm.collectionVariables.set('e2eEmail', email);",
                  "pm.request.body.raw = JSON.stringify({ name: 'E2E Test User', email: email, password: 'password123' });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Register returns 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Response has token, default FREE tier, contributionOptIn=true', function () {",
                  "    var d = pm.response.json();",
                  "    pm.expect(d.token).to.be.a('string');",
                  "    pm.expect(d.user.subscriptionTier).to.eql('FREE');",
                  "    pm.expect(d.user.contributionOptIn).to.eql(true);",
                  "    pm.collectionVariables.set('token', d.token);",
                  "    pm.collectionVariables.set('e2eUserId', d.user.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2. Login with registered user",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "pt"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{e2eEmail}}\",\n  \"password\": \"password123\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login returns 200', function () { pm.response.to.have.status(200); });",
                  "var d = pm.response.json();",
                  "pm.collectionVariables.set('token', d.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "3. Get my profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept-Language",
                "value": "pt"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "me"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Returns 200', function () { pm.response.to.have.status(200); });",
                  "var d = pm.response.json();",
                  "pm.test('Email matches registered email', function () {",
                  "    pm.expect(d.email).to.eql(pm.collectionVariables.get('e2eEmail'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4. Update my profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "pt"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "me"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated E2E User\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Returns 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Name updated', function () { pm.expect(pm.response.json().name).to.eql('Updated E2E User'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "5. Change password",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "pt"
