            "url": {"raw": "{{baseUrl}}/api/v1/insights/markets/top?limit=5", "host": ["{{baseUrl}}"], "path": ["api","v1","insights","markets","top"], "query": [
              {"key": "limit", "value": "5"}
            ]}
          },
          "response": []
        },
        {
          "name": "Top categories",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/insights/categories/top?limit=5", "host": ["{{baseUrl}}"], "path": ["api","v1","insights","categories","top"], "query": [
              {"key": "limit", "value": "5"}
            ]}
          },
          "response": []
        },
        {
          "name": "Price history for product",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/insights/products/{{e2eProductId}}/price-history", "host": ["{{baseUrl}}"], "path": ["api","v1","insights","products","{{e2eProductId}}","price-history"]}
          },
          "response": []
        }
      ]
    },
    {
      "name": "Categorizer",
      "description": "ML classifier status + manual triggers. Authenticated.",
      "item": [
        {
          "name": "Classifier status",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/categorizer/status", "host": ["{{baseUrl}}"], "path": ["api","v1","categorizer","status"]}
          },
          "response": []
        },
        {
          "name": "Retrain ML now",
          "request": {
            "method": "POST",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/categorizer/retrain", "host": ["{{baseUrl}}"], "path": ["api","v1","categorizer","retrain"]}
          },
          "response": []
        },
        {
          "name": "Auto-promote learned dictionary",
          "request": {
            "method": "POST",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/categorizer/auto-promote", "host": ["{{baseUrl}}"], "path": ["api","v1","categorizer","auto-promote"]}
          },
          "response": []
        }
      ]
    },
    {
      "name": "Price index (collaborative)",
      "description": "K-anonymity-protected aggregates. Will return empty until enough households contribute.",
      "item": [
        {
          "name": "Reference price for a (product, market)",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/price-index/products/{{e2eProductId}}/markets/93015006005182/reference", "host": ["{{baseUrl}}"], "path": ["api","v1","price-index","products","{{e2eProductId}}","markets","93015006005182","reference"]}
          },
          "response": []
        },
        {
          "name": "Best markets for a product",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/price-index/products/{{e2eProductId}}/best-markets?limit=10", "host": ["{{baseUrl}}"], "path": ["api","v1","price-index","products","{{e2eProductId}}","best-markets"], "query": [
              {"key": "limit", "value": "10"}
            ]}
          },
          "response": []
        },
        {
          "name": "Current community promos",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/price-index/promos", "host": ["{{baseUrl}}"], "path": ["api","v1","price-index","promos"]}
          },
          "response": []
        }
      ]
    },
    {
      "name": "E2E Flow",
      "description": "Sequential test suite — run top to bottom. Each step seeds variables for the next. Steps 9+ require a real NFC-e QR payload in the {{qrPayload}} collection variable; otherwise they will report parsing/fetch errors but won't break the auth/household flow.",
      "item": [
        {
          "name": "1. Register new user",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept-Language", "value": "pt"}
            ],
            "url": {"raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","register"]},
            "auth": {"type": "noauth"},
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"E2E Test User\",\n  \"email\": \"e2e@test.com\",\n  \"password\": \"password123\",\n  \"acceptedTermsVersion\": \"1.0\",\n  \"acceptedPrivacyVersion\": \"1.0\"\n}"}
          },
          "response": [],
          "event": [
            {"listen": "prerequest", "script": {"type": "text/javascript", "exec": [
              "var email = 'e2e-' + Date.now() + '@test.com';",
              "pm.collectionVariables.set('e2eEmail', email);",
              "pm.request.body.raw = JSON.stringify({ name: 'E2E Test User', email: email, password: 'password123', acceptedTermsVersion: '1.0', acceptedPrivacyVersion: '1.0' });"
            ]}},
            {"listen": "test", "script": {"type": "text/javascript", "exec": [
              "pm.test('Register returns 201', function () { pm.response.to.have.status(201); });",
              "pm.test('Response has token, default FREE tier, contributionOptIn=true', function () {",
              "    var d = pm.response.json();",
              "    pm.expect(d.token).to.be.a('string');",
              "    pm.expect(d.user.subscriptionTier).to.eql('FREE');",
              "    pm.expect(d.user.contributionOptIn).to.eql(true);",
              "    pm.collectionVariables.set('token', d.token);",
              "    pm.collectionVariables.set('e2eUserId', d.user.id);",
              "});"
            ]}}
          ]
        },
        {
          "name": "2. Login with registered user",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept-Language", "value": "pt"}
            ],
            "url": {"raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","login"]},
            "auth": {"type": "noauth"},
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"{{e2eEmail}}\",\n  \"password\": \"password123\"\n}"}
          },
          "response": [],
          "event": [
            {"listen": "test", "script": {"type": "text/javascript", "exec": [
              "pm.test('Login returns 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "pm.collectionVariables.set('token', d.token);"
            ]}}
          ]
        },
        {
          "name": "3. Get my profile",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/users/me", "host": ["{{baseUrl}}"], "path": ["api","v1","users","me"]}
          },
          "response": [],
          "event": [
            {"listen": "test", "script": {"type": "text/javascript", "exec": [
              "pm.test('Returns 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "pm.test('Email matches registered email', function () { pm.expect(d.email).to.eql(pm.collectionVariables.get('e2eEmail')); });"
            ]}}
          ]
        },
        {
          "name": "4. Update my profile",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept-Language", "value": "pt"}
            ],
            "url": {"raw": "{{baseUrl}}/api/v1/users/me", "host": ["{{baseUrl}}"], "path": ["api","v1","users","me"]},
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"Updated E2E User\"\n}"}
          },
          "response": [],
          "event": [
            {"listen": "test", "script": {"type": "text/javascript", "exec": [
              "pm.test('Returns 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Name updated', function () { pm.expect(pm.response.json().name).to.eql('Updated E2E User'); });"
            ]}}
          ]
        },
        {
          "name": "5. Change password",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept-Language", "value": "pt"}
            ],
