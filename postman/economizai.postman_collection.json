              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{e2eEmail}}\",\n  \"password\": \"newPassword123\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Returns 200 with new password', function () { pm.response.to.have.status(200); });",
                  "var d = pm.response.json();",
                  "pm.collectionVariables.set('token', d.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "7. Login with old password should fail",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "pt"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{e2eEmail}}\",\n  \"password\": \"password123\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Old password returns 401', function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
