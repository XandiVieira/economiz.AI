{
  "info": {
    "name": "economizai",
    "description": "API collection for the economizai backend (NFC-e collaborative price intelligence). Maintain in sync with every endpoint change. The 'E2E Flow' folder runs all requests in logical order — each request seeds variables for the next.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:8080", "type": "string"},
    {"key": "token", "value": "", "type": "string"},
    {"key": "e2eEmail", "value": "", "type": "string"},
    {"key": "e2eUserId", "value": "", "type": "string"},
    {"key": "e2eHouseholdId", "value": "", "type": "string"},
    {"key": "e2eInviteCode", "value": "", "type": "string"},
    {"key": "e2eReceiptId", "value": "", "type": "string"},
    {"key": "e2eReceiptItemId", "value": "", "type": "string"},
    {"key": "e2eProductId", "value": "", "type": "string"},
    {"key": "qrPayload", "value": "PASTE_REAL_NFCE_QR_PAYLOAD_HERE", "type": "string", "description": "Set this to a real NFC-e QR string (full SEFAZ URL or pipe-separated p= value) before running the receipt steps."}
  ],
  "item": [
    {
      "name": "Legal",
      "description": "Public endpoints — no auth needed.",
      "item": [
        {
          "name": "Get current Terms of Use",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/legal/terms", "host": ["{{baseUrl}}"], "path": ["api","v1","legal","terms"]},
            "auth": {"type": "noauth"}
          },
          "response": []
        },
        {
          "name": "Get current Privacy Policy",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/legal/privacy-policy", "host": ["{{baseUrl}}"], "path": ["api","v1","legal","privacy-policy"]},
            "auth": {"type": "noauth"}
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register new user",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept-Language", "value": "pt"}
            ],
            "url": {"raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","register"]},
            "auth": {"type": "noauth"},
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"Demo User\",\n  \"email\": \"demo@example.com\",\n  \"password\": \"password123\",\n  \"acceptedTermsVersion\": \"1.0\",\n  \"acceptedPrivacyVersion\": \"1.0\"\n}"}
          },
          "response": [],
          "event": [
            {"listen": "test", "script": {"type": "text/javascript", "exec": [
              "pm.test('Register returns 201', function () { pm.response.to.have.status(201); });",
              "var data = pm.response.json();",
              "if (data.token) pm.collectionVariables.set('token', data.token);"
            ]}}
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept-Language", "value": "pt"}
            ],
            "url": {"raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","login"]},
            "auth": {"type": "noauth"},
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"demo@example.com\",\n  \"password\": \"password123\"\n}"}
          },
          "response": [],
          "event": [
            {"listen": "test", "script": {"type": "text/javascript", "exec": [
              "pm.test('Login returns 200', function () { pm.response.to.have.status(200); });",
              "var data = pm.response.json();",
              "if (data.token) pm.collectionVariables.set('token', data.token);"
            ]}}
          ]
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get my profile",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/users/me", "host": ["{{baseUrl}}"], "path": ["api","v1","users","me"]}
          },
          "response": []
        },
        {
          "name": "Update my profile",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept-Language", "value": "pt"}
            ],
            "url": {"raw": "{{baseUrl}}/api/v1/users/me", "host": ["{{baseUrl}}"], "path": ["api","v1","users","me"]},
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"Updated Name\"\n}"}
          },
          "response": []
        },
        {
          "name": "Change password",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept-Language", "value": "pt"}
            ],
            "url": {"raw": "{{baseUrl}}/api/v1/users/me/password", "host": ["{{baseUrl}}"], "path": ["api","v1","users","me","password"]},
            "body": {"mode": "raw", "raw": "{\n  \"currentPassword\": \"password123\",\n  \"newPassword\": \"newPassword123\"\n}"}
          },
          "response": []
        },
        {
          "name": "Update collaborative contribution (LGPD opt-in/out)",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept-Language", "value": "pt"}
            ],
            "url": {"raw": "{{baseUrl}}/api/v1/users/me/contribution", "host": ["{{baseUrl}}"], "path": ["api","v1","users","me","contribution"]},
            "body": {"mode": "raw", "raw": "{\n  \"contributionOptIn\": false\n}"}
          },
          "response": []
        },
        {
          "name": "Export my data (LGPD Art. 18 V)",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/users/me/export", "host": ["{{baseUrl}}"], "path": ["api","v1","users","me","export"]}
          },
          "response": []
        },
        {
          "name": "Delete my account (LGPD Art. 18 VI)",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/users/me", "host": ["{{baseUrl}}"], "path": ["api","v1","users","me"]}
          },
          "response": []
        }
      ]
    },
    {
      "name": "Households",
      "item": [
        {
          "name": "Get my household",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/households/me", "host": ["{{baseUrl}}"], "path": ["api","v1","households","me"]}
          },
          "response": []
        },
        {
          "name": "Join household by invite code",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept-Language", "value": "pt"}
            ],
            "url": {"raw": "{{baseUrl}}/api/v1/households/join", "host": ["{{baseUrl}}"], "path": ["api","v1","households","join"]},
            "body": {"mode": "raw", "raw": "{\n  \"inviteCode\": \"ABC123\"\n}"}
          },
          "response": []
        },
        {
          "name": "Leave household",
          "request": {
            "method": "POST",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/households/leave", "host": ["{{baseUrl}}"], "path": ["api","v1","households","leave"]}
          },
          "response": []
        }
      ]
    },
    {
      "name": "Receipts",
      "item": [
        {
          "name": "Submit NFC-e QR",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept-Language", "value": "pt"}
            ],
            "url": {"raw": "{{baseUrl}}/api/v1/receipts", "host": ["{{baseUrl}}"], "path": ["api","v1","receipts"]},
            "body": {"mode": "raw", "raw": "{\n  \"qrPayload\": \"{{qrPayload}}\"\n}"}
          },
          "response": []
        },
        {
          "name": "List receipts (paginated)",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/receipts?page=0&size=20", "host": ["{{baseUrl}}"], "path": ["api","v1","receipts"], "query": [
              {"key": "page", "value": "0"},
              {"key": "size", "value": "20"}
            ]}
          },
          "response": []
        },
        {
          "name": "Get receipt by id",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/receipts/{{e2eReceiptId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","receipts","{{e2eReceiptId}}"]}
          },
          "response": []
        },
        {
          "name": "Update receipt item",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept-Language", "value": "pt"}
            ],
            "url": {"raw": "{{baseUrl}}/api/v1/receipts/{{e2eReceiptId}}/items/{{e2eReceiptItemId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","receipts","{{e2eReceiptId}}","items","{{e2eReceiptItemId}}"]},
            "body": {"mode": "raw", "raw": "{\n  \"rawDescription\": \"ARROZ TIO JOAO TIPO 1 5KG\",\n  \"ean\": \"7891234567890\",\n  \"quantity\": 2,\n  \"unit\": \"UN\",\n  \"unitPrice\": 28.90,\n  \"totalPrice\": 57.80\n}"}
          },
          "response": []
        },
        {
          "name": "Confirm receipt",
          "request": {
            "method": "POST",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/receipts/{{e2eReceiptId}}/confirm", "host": ["{{baseUrl}}"], "path": ["api","v1","receipts","{{e2eReceiptId}}","confirm"]}
          },
          "response": []
        },
        {
          "name": "Reject receipt",
          "request": {
            "method": "POST",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/receipts/{{e2eReceiptId}}/reject", "host": ["{{baseUrl}}"], "path": ["api","v1","receipts","{{e2eReceiptId}}","reject"]}
          },
          "response": []
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Search products",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/products?query=arroz&page=0&size=20", "host": ["{{baseUrl}}"], "path": ["api","v1","products"], "query": [
              {"key": "query", "value": "arroz"},
              {"key": "page", "value": "0"},
              {"key": "size", "value": "20"}
            ]}
          },
          "response": []
        },
        {
          "name": "List unmatched items (review queue)",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/products/unmatched", "host": ["{{baseUrl}}"], "path": ["api","v1","products","unmatched"]}
          },
          "response": []
        },
        {
          "name": "Create canonical product",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept-Language", "value": "pt"}
            ],
            "url": {"raw": "{{baseUrl}}/api/v1/products", "host": ["{{baseUrl}}"], "path": ["api","v1","products"]},
            "body": {"mode": "raw", "raw": "{\n  \"ean\": \"7891234567890\",\n  \"normalizedName\": \"Arroz Tio Joao Tipo 1 5kg\",\n  \"brand\": \"Tio Joao\",\n  \"category\": \"GROCERIES\",\n  \"unit\": \"UN\"\n}"}
          },
          "response": []
        },
        {
          "name": "Update product (set category/brand)",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept-Language", "value": "pt"}
            ],
            "url": {"raw": "{{baseUrl}}/api/v1/products/{{e2eProductId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","products","{{e2eProductId}}"]},
            "body": {"mode": "raw", "raw": "{\n  \"normalizedName\": \"Arroz Tio Joao Tipo 1 5kg\",\n  \"brand\": \"Tio Joao\",\n  \"category\": \"GROCERIES\",\n  \"unit\": \"UN\"\n}"}
          },
          "response": []
        },
        {
          "name": "Add alias to product (links unmatched items)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept-Language", "value": "pt"}
            ],
            "url": {"raw": "{{baseUrl}}/api/v1/products/{{e2eProductId}}/aliases", "host": ["{{baseUrl}}"], "path": ["api","v1","products","{{e2eProductId}}","aliases"]},
            "body": {"mode": "raw", "raw": "{\n  \"rawDescription\": \"ARROZ TIO J TP1 5KG\"\n}"}
          },
          "response": []
        }
      ]
    },
    {
      "name": "Insights",
      "item": [
        {
          "name": "Spend dashboard (all time)",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/insights/spend", "host": ["{{baseUrl}}"], "path": ["api","v1","insights","spend"]}
          },
          "response": []
        },
        {
          "name": "Spend dashboard (date range)",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept-Language", "value": "pt"}],
            "url": {"raw": "{{baseUrl}}/api/v1/insights/spend?from=2026-01-01T00:00:00&to=2026-12-31T23:59:59", "host": ["{{baseUrl}}"], "path": ["api","v1","insights","spend"], "query": [
              {"key": "from", "value": "2026-01-01T00:00:00"},
              {"key": "to", "value": "2026-12-31T23:59:59"}
