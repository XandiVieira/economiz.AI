# === Backend Environment Variables ===
# Local dev: copy to .env (which is gitignored) and fill in real values.
# Render: set these in the service's "Environment" tab.

# Database
# Local: jdbc:postgresql://localhost:5432/economizai
# Render: when you link a PostgreSQL add-on, Render exposes the URL as
# `DATABASE_URL` in postgres://user:pass@host/db form. Spring needs the
# JDBC form, so override DATABASE_URL with the JDBC variant manually,
# OR map Render's URL into DB_USERNAME / DB_PASSWORD and build the
# JDBC URL from "Internal Database URL" host/port/db.
DATABASE_URL=jdbc:postgresql://localhost:5432/economizai
DB_USERNAME=economizai
DB_PASSWORD=economizai

# JWT (MUST change for production — generate a random 64+ char string)
JWT_SECRET=your-super-secret-key-at-least-256-bits-long-change-this-in-production

# CORS (comma-separated list of allowed frontend origins).
# Set to your Render frontend URL in production.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# SMTP (for email verification + password reset — optional for early dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Password reset link base URL (frontend will pick up the token)
RESET_BASE_URL=http://localhost:3000/reset-password
