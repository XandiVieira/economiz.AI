# economizai — environment variable template
# =============================================
# This file is the LOCAL DEV template only. Copy to `.env` (gitignored)
# and fill in real values for your machine.
#
# DO NOT IMPORT THIS FILE INTO RENDER. It contains localhost defaults
# and placeholder secrets that would either break the deploy (DB at
# localhost) or weaken security (predictable JWT secret).
#
# For Render, set the production values directly in the Environment tab
# (or import a separate file containing the real production credentials —
# never commit that file).

# === Database ===
# Local dev: keep these defaults if you run Postgres on localhost.
# Render: paste the JDBC-form URL from your Postgres add-on.
#         Render's "Internal Database URL" comes as postgres://...; rewrite
#         the protocol to `jdbc:postgresql://...` for Spring.
DATABASE_URL=jdbc:postgresql://localhost:5432/economizai
DB_USERNAME=economizai
DB_PASSWORD=economizai

# === JWT ===
# Production MUST set this to a real random 64+ char secret.
# Generate one with:  openssl rand -hex 64
JWT_SECRET=local-dev-only-secret-not-for-production-must-be-at-least-256-bits-long

# === CORS ===
# Comma-separated list of allowed FE origins. Production should include the
# deployed FE URL (and remove the localhost entries unless you want devs to
# hit prod from their machines).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# === Notifications ===
# Email is OFF by default — turn on once SMTP creds are wired.
NOTIFICATIONS_EMAIL_ENABLED=false
EMAIL_FROM=noreply@economiz.ai

# SMTP (only consulted when NOTIFICATIONS_EMAIL_ENABLED=true)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
